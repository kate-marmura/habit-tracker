# Database
# When running in Docker containers, use "db" as the host (Docker service name).
# When running locally (outside Docker), use "localhost".
DATABASE_URL=postgresql://postgres:postgres@db:5432/habit_tracker

# Docker PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=habit_tracker

# Auth
JWT_SECRET=dev-secret-change-in-production-min-256-bits
JWT_EXPIRY=7d

# Email (required in production for password reset; optional in dev/test)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@habittracker.app

# App
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# AI (Phase 2)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
